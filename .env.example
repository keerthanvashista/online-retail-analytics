# Copy this file to .env and fill in your actual values.
# .env itself is git-ignored and will never be committed — only this
# .env.example template is tracked, so anyone cloning the repo knows
# what to configure without ever seeing a real password.

MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=retail_analytics
